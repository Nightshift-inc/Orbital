# Orbital — root environment configuration
# Copy to .env and fill in values for local development.

NODE_ENV=development
LOG_LEVEL=info

# Service URLs (used by api-gateway and payment-gateway to reach auth-service)
AUTH_SERVICE_URL=http://auth-service:4001
PAYMENT_SERVICE_URL=http://payment-gateway:4002

# Service ports
AUTH_SERVICE_PORT=4001
PAYMENT_SERVICE_PORT=4002
GATEWAY_PORT=4000

# Shared infrastructure
DATABASE_URL=postgres://orbital:orbital@localhost:5432/orbital_dev
REDIS_URL=redis://localhost:6379/0

# Third-party integrations (demo stubs — not real credentials)
STRIPE_API_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Session signing
SESSION_COOKIE_SECRET=replace-me-for-production
SESSION_TTL_SECONDS=3600
