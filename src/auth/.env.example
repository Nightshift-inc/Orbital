# auth-service — environment configuration

AUTH_SERVICE_PORT=4001
NODE_ENV=development

# Session signing
SESSION_COOKIE_SECRET=replace-me-for-production
SESSION_TTL_SECONDS=3600

# Infrastructure
DATABASE_URL=postgres://orbital:orbital@localhost:5432/orbital_dev
REDIS_URL=redis://localhost:6379/0

# Feature flags
ENABLE_2FA=true
ENABLE_MAGIC_LINK_LOGIN=true
