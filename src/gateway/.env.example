# api-gateway — environment configuration

GATEWAY_PORT=4000
NODE_ENV=development

# Downstream service URLs — api-gateway depends on both
AUTH_SERVICE_URL=http://auth-service:4001
PAYMENT_SERVICE_URL=http://payment-gateway:4002

# Per-tier rate limits (requests per minute)
RATE_LIMIT_FREE=60
RATE_LIMIT_STARTER=600
RATE_LIMIT_GROWTH=6000
RATE_LIMIT_SCALE=30000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
